[user]
    # IMPORTANT: Set your name and email
    name = Your Name
    email = your@email.com
[pull]
	rebase = true
[rebase]
	autoStash = true
[fetch]
	prune = true
[diff]
	colorMoved = zebra
    tool = nvimdiff
[init]
    defaultBranch = main
[core]
    # Set nvim as your default editor
    editor = nvim
[merge]
    tool = nvimdiff
[mergetool "nvimdiff"]
    # Command for a 3-way merge in nvim
    cmd = nvim -d -c 'wincmd J' "$LOCAL" "$REMOTE" "$MERGED"
[difftool "nvimdiff"]
    path = nvim
    cmd = nvim -d "$LOCAL" "$REMOTE"
[difftool]
    prompt = false
[alias]
    # More useful aliases
    diffheads = difftool HEAD^ HEAD
    s = status -s
    st = status
    co = checkout
    br = branch
    ci = commit
    lg = log --oneline --graph --decorate --all
